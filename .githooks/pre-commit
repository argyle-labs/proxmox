#!/usr/bin/env bash
# Auto-format staged Rust before commit, then re-stage exactly the originally
# staged paths so the commit captures the formatted bytes. Keeps every commit
# fmt-clean (the pre-push `fmt --check` then never trips).
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACMR)
[ ${#STAGED[@]} -eq 0 ] && exit 0

for f in "${STAGED[@]}"; do
  if [[ $f == *.rs ]]; then
    echo "==> rustfmt"
    cargo fmt --all
    git add -- "${STAGED[@]}"
    break
  fi
done
